# Celestia / Lumina node
CELESTIA_RPC_URL=http://localhost:26658
CELESTIA_NETWORK=mocha-4
# JWT auth token from `lumina node auth` — leave empty if node has auth disabled
CELESTIA_AUTH_TOKEN=

# ZKPassport
NEXT_PUBLIC_ZKPASSPORT_DOMAIN=localhost:3000
ZKPASSPORT_APP_NAME=ZK Vote Celestia
ZKPASSPORT_APP_LOGO_URL=https://example.com/logo.png
# true = accept mock proof format proof="mock:<unique_user_id>" and derive scoped nullifier server-side
MOCK_ZKPASSPORT=false

# Admin
ADMIN_API_KEY=change-me-before-deploy

# Database (SQLite file path)
DATABASE_URL=file:./db/zkvote.db
